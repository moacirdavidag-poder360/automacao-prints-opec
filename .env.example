NODE_ENV= # ambiente

# Google Drive (para salvar os prints)
ID_PASTA_GOOGLE_DRIVE= # ID da pasta no Google Drive onde os prints são salvos
GOOGLE_CREDENTIALS_B64= # base64 do secret.json

# Planilha de automação de prints 
# (Sempre atualize mensalmente - quando terminar o mês, crie um backup)
# E atualize a planilha com as novas campanhas
PLANILHA_CAMPANHAS_ID= # ID da planilha (A QUE VAI SER USADA TODO mÊS)
NOME_ABA_PLANILHA= # Nome da aba da planilha, por padrão "Página 1"

# Conexão com o banco de dados para puxar as campanhas
MONGO_URI= # URL do mongo para o poder-ads